# ── WhatsApp (Meta Developer Console) ────────────────────────────
WA_TOKEN=EAAL...твой_токен
WA_PHONE_ID=1234567890123456
WA_VERIFY=любая_строка_которую_ты_придумал

# ── AI (Groq) ─────────────────────────────────────────────────────
GROQ_KEY=gsk_...

# ── Админка ───────────────────────────────────────────────────────
ADMIN_PASSWORD=admin123

# ── База данных ───────────────────────────────────────────────────
# Railway подставляет DATABASE_URL автоматически через плагин PostgreSQL.
# Для локальной разработки не задавай — будет использоваться SQLite (bot.db).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Фичи (true/false) ─────────────────────────────────────────────
FEATURE_MEMORY=true
FEATURE_FUNNEL=true
FEATURE_CRM=false
FEATURE_SPAM=true
FEATURE_HANDOFF=true
